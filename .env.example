# =============================================================================
# FireGuard — Environment Variables (TEMPLATE)
# =============================================================================
# Copy ke .env dan isi dengan kredensial Anda.
# JANGAN PERNAH COMMIT FILE .env — sudah ada di .gitignore.
#
#   cp .env.example .env
# =============================================================================

# NASA FIRMS API key (daftar gratis di https://firms.modaps.eosdis.nasa.gov/api/map_key/)
NASA_FIRMS_API_KEY=

# BMKG (saat ini publik tanpa key, sediakan kalau berubah)
BMKG_API_KEY=

# DVC remote storage (S3 atau GDrive)
# Contoh S3:
# DVC_REMOTE_URL=s3://my-bucket/fireguard-dvc
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=

# MLflow tracking (default ke file lokal; ganti jika pakai server remote)
MLFLOW_TRACKING_URI=file:./mlruns

# Environment label (development / staging / production)
APP_ENV=development
