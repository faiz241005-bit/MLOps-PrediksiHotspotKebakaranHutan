# =============================================================================
# FireGuard MLOps — .gitignore
# =============================================================================
# Mencegah kebocoran kredensial, data besar, dan artifact yang seharusnya
# tidak masuk ke version control.
# =============================================================================

# --- Secrets & credentials (CRITICAL — jangan pernah dihapus) ----------------
.env
.env.*
secrets/
*.key
*.pem
*.p12
credentials.json
service-account*.json

# NASA FIRMS API key — biasanya disimpan di env atau secrets
firms_api_key.txt
*.token

# --- Python ------------------------------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# --- Virtual environments ----------------------------------------------------
.venv/
venv/
env/
ENV/
.python-version

# --- IDE / Editor ------------------------------------------------------------
.vscode/
.idea/
*.swp
*.swo
*~
.DS_Store
Thumbs.db

# --- Container bind-mount side effects ---------------------------------------
# .config folder dibuat container webhook-receiver via bind mount /:/app
.config/
.cache/

# --- Test artifacts (jaga-jaga kalau pytest dijalankan lagi) -----------------
.pytest_cache/

# --- DVC ---------------------------------------------------------------------
# DVC tracks data lewat .dvc files; data binary tidak boleh masuk Git.
/data/raw/*
/data/processed/*
/data/features/*
!/data/raw/.gitkeep
!/data/processed/.gitkeep
!/data/features/.gitkeep
!/data/**/*.dvc

# DVC cache (lokal, tidak perlu commit)
.dvc/cache
.dvc/tmp
.dvc/plots

# DVC local remote storage (LK12 — persistent local store, bukan /tmp)
/dvc-storage/*
!/dvc-storage/.gitkeep

# --- Models ------------------------------------------------------------------
/models/*
!/models/.gitkeep
!/models/**/*.dvc
*.pkl
*.joblib
*.h5
*.pt
*.pth
*.onnx

# --- MLflow ------------------------------------------------------------------
mlruns/
mlartifacts/
mlflow.db

# --- Logs --------------------------------------------------------------------
logs/
*.log
*.log.*

# --- Docker ------------------------------------------------------------------
*.dockerignore.bak

# --- OS ----------------------------------------------------------------------
.AppleDouble
.LSOverride
$RECYCLE.BIN/
ehthumbs.db
secrets/
/mlruns
/mlflow-backup.db
/mlflow-artifacts-backup
