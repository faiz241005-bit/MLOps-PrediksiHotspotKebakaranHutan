# =============================================================================
# Docker build context exclusions
# Tujuan: kecilkan build context + cegah leak file sensitif ke image.
# =============================================================================

# Secrets & local config
.env
.env.*
*.pem
*.key

# Git metadata
.git
.gitignore
.gitattributes
.github

# Python build artefacts
__pycache__
*.py[cod]
*.so
*.egg-info
.eggs
build
dist

# Virtualenvs
.venv
venv
env

# Editor & OS
.vscode
.idea
.DS_Store
Thumbs.db

# DVC & big data — TIDAK perlu masuk image (mount via volume kalau perlu)
.dvc/cache
.dvc/tmp
dvc-storage
data/raw
data/processed
data/features
data/external
mlruns
mlartifacts
*.parquet
*.csv

# Docs (tidak dibutuhkan saat serve)
*.md
LICENSE
LK*.docx
LK*.pdf

# Devcontainer
.devcontainer
