{
  "name": "MLOps-FireGuard (Python 3.11)",
  "build": {
    "dockerfile": "Dockerfile"
  },

  "features": {
    "ghcr.io/devcontainers/features/docker-outside-of-docker:1": {
      "version": "latest",
      "moby": true,
      "installDockerComposeSwitch": true
    }
  },

  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python",
        "ms-python.vscode-pylance",
        "ms-python.black-formatter",
        "ms-python.flake8",
        "ms-python.isort",
        "ms-toolsai.jupyter",
        "ms-toolsai.jupyter-keymap",
        "ms-toolsai.jupyter-renderers",
        "ms-toolsai.vscode-jupyter-cell-tags",
        "iterative.dvc",
        "redhat.vscode-yaml",
        "tamasfe.even-better-toml",
        "GitHub.vscode-pull-request-github",
        "GitHub.vscode-github-actions",
        "eamodio.gitlens",
        "yzhang.markdown-all-in-one",
        "njpwerner.autodocstring"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/usr/local/bin/python",
        "python.formatting.provider": "black",
        "python.linting.flake8Enabled": true,
        "python.linting.enabled": true,
        "editor.formatOnSave": true,
        "editor.rulers": [88, 100],
        "files.trimTrailingWhitespace": true,
        "files.insertFinalNewline": true,
        "[python]": {
          "editor.defaultFormatter": "ms-python.black-formatter"
        },
        "jupyter.askForKernelRestart": false,
        "terminal.integrated.defaultProfile.linux": "bash",

        // ── PORTS CLEANUP ──
        // Cegah VS Code auto-forward random high ports dari ekstensi internal.
        // Hanya port di "forwardPorts" yang akan muncul di tab Ports.
        "remote.autoForwardPorts": false
      }
    }
  },

  "postCreateCommand": "pip install --upgrade pip && pip install -r requirements.txt && pre-commit install || true",

  // ── PORTS — hanya yang penting (LK09 + LK10 + LK11 + LK12) ──
  "forwardPorts": [3000, 5000, 8010, 8085, 8501, 9000, 9090, 9100],
  "portsAttributes": {
    "3000": { "label": "Grafana (LK11)",             "onAutoForward": "notify" },
    "5000": { "label": "MLflow Tracking UI",         "onAutoForward": "silent" },
    "8010": { "label": "mlflow-model-server (rep1)", "onAutoForward": "silent" },
    "8085": { "label": "cAdvisor (LK11)",            "onAutoForward": "silent" },
    "8501": { "label": "Streamlit Dashboard",        "onAutoForward": "notify" },
    "9000": { "label": "metrics-proxy (LK11)",       "onAutoForward": "silent" },
    "9090": { "label": "Prometheus (LK11)",          "onAutoForward": "silent" },
    "9100": { "label": "webhook-receiver (LK12)",    "onAutoForward": "silent" }
  },

  "remoteEnv": {
    "PYTHONPATH": "${containerWorkspaceFolder}:${containerWorkspaceFolder}/src",
    "MLFLOW_TRACKING_URI": "file://${containerWorkspaceFolder}/mlruns"
  },

  "containerEnv": {
    "PYTHONDONTWRITEBYTECODE": "1",
    "PYTHONUNBUFFERED": "1"
  },

  "remoteUser": "vscode"
}
